{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-theme",
    "deep-link:default",
    "dialog:default",
    "opener:default",
    "ai:default"
  ]
}
