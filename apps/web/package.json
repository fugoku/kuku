{
  "name": "@kuku/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "imports:check": "node scripts/check_parent_imports.mjs",
    "lint:check": "oxlint .",
    "lint": "oxlint --fix .",
    "lint:check:full": "pnpm lint:check && pnpm imports:check && astro check",
    "format:check": "oxfmt --check .",
    "format": "oxfmt --write .",
    "format:check:full": "pnpm format:check && prettier --check \"src/**/*.astro\"",
    "format:full": "pnpm format && prettier --write \"src/**/*.astro\""
  },
  "dependencies": {
    "astro": "^6.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "~5.9.3"
  }
}
